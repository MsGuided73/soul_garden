# ── Soul Garden .dockerignore ──
# Keep the Docker build context lean and secure.

# Secrets — NEVER include
.env
.env.*
!.env.example

# Git
.git
.gitignore

# Shelved backend (not needed for static build)
backend.shelved/

# Python Layer 3 tools (not needed at build time)
tools/
.tmp/

# Node
node_modules/

# Documentation & architecture
docs/
architecture/
database/
*.md
!README.md

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db
.DS_Store

# Disabled configs
nixpacks.toml*

# Agent soul files (not needed in Docker)
___SUMNER/
sumner_soul.md
lore.md
AGENT_GUIDELINES.md
drift_log.json
soul_loader.py
