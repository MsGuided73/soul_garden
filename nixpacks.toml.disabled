# Nixpacks configuration for Soul Garden Unified Deployment

[phases.setup]
nixPkgs = ["nodejs", "python3", "python311Packages.pip"]

[phases.install]
cmds = [
    "npm install",
    "pip install -r backend/requirements.txt"
]

[phases.build]
cmds = ["npm run build"]

[start]
cmd = "cd backend && uvicorn main:app --host 0.0.0.0 --port 3000"
